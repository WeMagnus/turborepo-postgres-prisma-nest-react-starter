generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model CounterState {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("counter_states")
}

model Note {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  body      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notes")
}
